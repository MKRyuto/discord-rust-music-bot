DISCORD_TOKEN=your_discord_bot_token_here
# DEV_GUILD_ID optional. Kalau diisi, slash command didaftarkan cepat ke 1 server.
# Kalau kosong, command didaftarkan global.
DEV_GUILD_ID=
MUSIC_DB_PATH=music_bot.db
# Online SQLite backup. Point the directory at persistent storage in production.
MUSIC_DB_BACKUP_ENABLED=true
MUSIC_DB_BACKUP_DIR=backups
MUSIC_DB_BACKUP_INTERVAL_HOURS=24
MUSIC_DB_BACKUP_RETENTION=7

# Web dashboard. Set WEB_ENABLED=false to run the Discord bot without HTTP.
WEB_ENABLED=true
# Preview only: run the landing page without connecting the Discord bot.
WEB_PREVIEW=false
WEB_BIND=127.0.0.1:3000
PUBLIC_BASE_URL=http://127.0.0.1:3000
PUBLIC_CONTACT_EMAIL=

# Discord OAuth2 credentials from Developer Portal > OAuth2.
# DISCORD_CLIENT_ID defaults to the connected bot user ID when omitted.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URL=http://127.0.0.1:3000/auth/callback
# Minimum 32 random characters. Keep stable across deploys to restore encrypted sessions.
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Optional preview-only branding. Normal mode always uses the Discord bot profile.
BOT_DISPLAY_NAME=Music Bot
BOT_AVATAR_URL=
